<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <connectionStrings>
    

    <add name="con" connectionString="Data Source=mssql2017.adnshost.com,1533; Database=loanmarch26; User id=loanmarch26; password=Future@2575;Max Pool Size=50000" providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.net>
    <mailSettings>
      <smtp>
        <!-- Add SMTP configuration here -->
      </smtp>
    </mailSettings>
  </system.net>

  <system.web>
    <globalization requestEncoding="utf-8" responseEncoding="utf-8" />

    <sessionState timeout="30" />

    <!-- targetFramework attribute requires .NET 4.0 or higher; ensure your app pool uses .NET 4 -->
    <compilation debug="true" targetFramework="4.0" />

    <httpRuntime requestValidationMode="2.0" />

    <customErrors mode="Off" />

    <pages validateRequest="false"
           enableEventValidation="false"
           controlRenderingCompatibilityVersion="3.5"
           clientIDMode="AutoID" />
  </system.web>

  <system.webServer>
    <directoryBrowse enabled="true" />

    <modules runAllManagedModulesForAllRequests="true">
      <add name="SqlInjection" type="SqlInjection" />
    </modules>

    <defaultDocument>
      <files>
        <clear />
        <add value="login.aspx" />
      </files>
    </defaultDocument>

    <httpErrors errorMode="DetailedLocalOnly" existingResponse="Auto" />
  </system.webServer>

  <appSettings>
    <add key="aspnet:MaxHttpCollectionKeys" value="10000" />
  </appSettings>

</configuration>
